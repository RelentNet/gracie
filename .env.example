# ============================================================================
# GA App (gracie) — environment reference (.env.example)
# Source of truth: docs/07-integrations.md (consolidated section).
#
# NOTE (Phase 1A scaffold): NONE of these are required to build or run the
# scaffold. The app is wired to interfaces/stubs only — real integrations are
# wired in Phase 1B. Copy this file to `.env` and fill in when integrating.
# Actual build values live in the git-ignored docs/SECRETS.md.
# ============================================================================

# --- Bootstrap (env-only, required at startup once integrations land) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_ENCRYPTION_KEY=             # encrypts integration_credentials secrets
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_SECRET=
LOGTO_BASE_URL=                 # app origin Logto redirects back to (e.g. http://localhost:3000)

# --- Microsoft Graph (calendar, app-level, group-scoped) ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_CALENDAR_GROUP_ID=

# --- Rotatable (fallback; overridable in Admin > API Settings) ---
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=
RECALL_REGION=
OPENAI_API_KEY=
RESEND_API_KEY=
# RESEND_FROM must be an address on the Resend-VERIFIED sending domain (P7 §7).
# Gracie sends INTERNAL/team email ONLY — recipients are allowlist-gated to
# @graceandassociates.com (settings.email_allowed_domains). e.g. "Gracie <gracie@graceandassociates.com>"
RESEND_FROM=
# Base URL used in outbound-email links (P7). Defaults to the deployed origin.
APP_BASE_URL=                   # e.g. https://gracie.graceandassociates.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# --- Web access for the Assistant + Intelligence chats (P6B.2) ---
# Base URL of a self-hosted SearXNG instance (run it in Coolify or a VM). Powers
# the `web_search` tool behind the per-chat "Web" toggle. Leave unset to disable
# search (the `fetch_url` "read a specific page" tool works regardless).
# SearXNG setup: enable JSON output (settings.yml `search.formats: [html, json]`)
# and relax/allowlist the bot limiter so programmatic calls succeed.
SEARXNG_URL=                    # e.g. https://searxng.yourhost

# --- Worker / queue ---
REDIS_URL=

# --- n8n (its own container) ---
GA_API_TOKEN=
