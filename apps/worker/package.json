{
  "name": "@gracie/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify + BullMQ worker — long-running pipeline jobs and scheduled crons.",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env.local src/index.ts",
    "start": "tsx --env-file-if-exists=.env.local src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@bull-board/api": "^6.7.0",
    "@bull-board/fastify": "^6.7.0",
    "@gracie/db": "workspace:*",
    "@gracie/shared": "workspace:*",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "mammoth": "^1.9.0",
    "papaparse": "^5.4.1",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@gracie/config": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.3.15",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
